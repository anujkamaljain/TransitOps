model Vehicle {
  id                 String        @id @default(cuid())
  registrationNumber String        @unique
  name               String
  type               VehicleType
  maxLoadCapacityKg  Decimal       @db.Decimal(10, 2)
  odometer           Int           @default(0)
  acquisitionCost    Decimal       @db.Decimal(14, 2)
  status             VehicleStatus @default(AVAILABLE)
  region             String?
  acquiredAt         DateTime?
  notes              String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  trips           Trip[]
  maintenanceLogs MaintenanceLog[]
  fuelLogs        FuelLog[]
  expenses        Expense[]
  documents       VehicleDocument[]

  @@index([status])
  @@index([type])
  @@index([region])
  @@map("vehicles")
}

model Driver {
  id              String          @id @default(cuid())
  fullName        String
  licenseNumber   String          @unique
  licenseCategory LicenseCategory
  licenseExpiry   DateTime
  contactNumber   String
  email           String?
  safetyScore     Int             @default(100)
  status          DriverStatus    @default(AVAILABLE)
  region          String?
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  trips Trip[]

  @@index([status])
  @@index([licenseExpiry])
  @@index([region])
  @@map("drivers")
}

model VehicleDocument {
  id           String       @id @default(cuid())
  vehicleId    String
  vehicle      Vehicle      @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  type         DocumentType
  title        String
  fileUrl      String
  issueDate    DateTime?
  expiryDate   DateTime?
  uploadedById String?
  uploadedBy   User?        @relation("DocumentUploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([vehicleId])
  @@index([type])
  @@index([expiryDate])
  @@map("vehicle_documents")
}
