model Trip {
  id                String     @id @default(cuid())
  tripCode          String     @unique
  source            String
  destination       String
  vehicleId         String?
  vehicle           Vehicle?   @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  driverId          String?
  driver            Driver?    @relation(fields: [driverId], references: [id], onDelete: Restrict)
  cargoWeightKg     Decimal    @db.Decimal(10, 2)
  plannedDistanceKm Decimal    @db.Decimal(10, 2)
  actualDistanceKm  Decimal?   @db.Decimal(10, 2)
  status            TripStatus @default(DRAFT)
  etaMinutes        Int?
  revenue           Decimal?   @db.Decimal(14, 2)
  startOdometer     Int?
  endOdometer       Int?
  fuelConsumedL     Decimal?   @db.Decimal(10, 2)
  dispatchedAt      DateTime?
  completedAt       DateTime?
  cancelledAt       DateTime?
  notes             String?
  createdById       String?
  createdBy         User?      @relation("TripCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  fuelLogs FuelLog[]
  expenses Expense[]

  @@index([status])
  @@index([vehicleId])
  @@index([driverId])
  @@index([createdAt])
  @@map("trips")
}

model MaintenanceLog {
  id                String            @id @default(cuid())
  vehicleId         String
  vehicle           Vehicle           @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  serviceType       String
  description       String?
  cost              Decimal           @db.Decimal(12, 2)
  serviceDate       DateTime
  status            MaintenanceStatus @default(ACTIVE)
  odometerAtService Int?
  closedAt          DateTime?
  loggedById        String?
  loggedBy          User?             @relation("MaintenanceLoggedBy", fields: [loggedById], references: [id], onDelete: SetNull)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  expenses Expense[]

  @@index([vehicleId])
  @@index([status])
  @@map("maintenance_logs")
}

model FuelLog {
  id         String    @id @default(cuid())
  vehicleId  String
  vehicle    Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  tripId     String?
  trip       Trip?     @relation(fields: [tripId], references: [id], onDelete: SetNull)
  liters     Decimal   @db.Decimal(10, 2)
  cost       Decimal   @db.Decimal(12, 2)
  fuelType   FuelType?
  odometer   Int?
  filledAt   DateTime
  loggedById String?
  loggedBy   User?     @relation("FuelLoggedBy", fields: [loggedById], references: [id], onDelete: SetNull)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([vehicleId])
  @@index([tripId])
  @@index([filledAt])
  @@map("fuel_logs")
}

model Expense {
  id               String          @id @default(cuid())
  type             ExpenseType
  amount           Decimal         @db.Decimal(12, 2)
  description      String?
  incurredAt       DateTime
  vehicleId        String?
  vehicle          Vehicle?        @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  tripId           String?
  trip             Trip?           @relation(fields: [tripId], references: [id], onDelete: SetNull)
  maintenanceLogId String?
  maintenanceLog   MaintenanceLog? @relation(fields: [maintenanceLogId], references: [id], onDelete: SetNull)
  loggedById       String?
  loggedBy         User?           @relation("ExpenseLoggedBy", fields: [loggedById], references: [id], onDelete: SetNull)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([type])
  @@index([vehicleId])
  @@index([tripId])
  @@index([incurredAt])
  @@map("expenses")
}
