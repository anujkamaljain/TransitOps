# PostgreSQL connection string for local development
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/transitops?schema=public"

# Server
PORT=4000
NODE_ENV=development

# CORS - comma-separated allowed frontend origins (no trailing slash)
CLIENT_URL=http://localhost:5173,https://transit-ops-psi.vercel.app

# JWT access token secret (change this to a strong random value)
JWT_ACCESS_SECRET=change-me-access-secret
# Token lifetimes (drive both the JWT expiry and cookie/refresh TTLs)
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
