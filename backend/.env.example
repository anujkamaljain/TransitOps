# PostgreSQL connection string for local development
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/transitops?schema=public"

# Server
PORT=4000
NODE_ENV=development

# CORS - allowed frontend origin
CLIENT_URL=http://localhost:5173

# JWT secrets (change these to strong random values)
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
